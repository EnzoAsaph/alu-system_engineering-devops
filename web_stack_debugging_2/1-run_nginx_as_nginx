#!/usr/bin/env bash
# Configures the container so Nginx runs as the nginx user and listens on port 8080
id nginx >/dev/null 2>&1 || useradd -r nginx
service apache2 stop >/dev/null 2>&1
pkill apache2 >/dev/null 2>&1
sed -i 's/^user .*;/user nginx;/' /etc/nginx/nginx.conf
sed -i 's/^#user .*;/user nginx;/' /etc/nginx/nginx.conf
if [ -f /etc/nginx/sites-available/default ]; then
    sed -i 's/listen 80 /listen 8080 /g' /etc/nginx/sites-available/default
    sed -i 's/listen \[::\]:80 /listen [::]:8080 /g' /etc/nginx/sites-available/default
fi
if [ -f /etc/nginx/sites-enabled/default ]; then
    sed -i 's/listen 80 /listen 8080 /g' /etc/nginx/sites-enabled/default
    sed -i 's/listen \[::\]:80 /listen [::]:8080 /g' /etc/nginx/sites-enabled/default
fi
if [ -f /etc/nginx/conf.d/default.conf ]; then
    sed -i 's/listen  *80;/listen 8080;/g' /etc/nginx/conf.d/default.conf
fi
mkdir -p /var/lib/nginx /var/log/nginx
touch /run/nginx.pid
chown -R nginx:nginx /etc/nginx /var/lib/nginx /var/log/nginx /run/nginx.pid
pkill nginx >/dev/null 2>&1
sleep 1
su nginx -s /bin/bash -c '/usr/sbin/nginx'
sleep 1
pgrep nginx >/dev/null || /usr/sbin/nginx
