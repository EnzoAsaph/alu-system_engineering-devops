#!/usr/bin/env bash
# Configures the container so Nginx runs as the nginx user and listens on port 8080
sed -i 's/^user .*;/user nginx;/' /etc/nginx/nginx.conf
sed -i 's/^#user .*;/user nginx;/' /etc/nginx/nginx.conf
sed -i 's/listen 80 default_server/listen 8080 default_server/' /etc/nginx/sites-available/default
sed -i 's/listen \[::\]:80 default_server/listen [::]:8080 default_server/' /etc/nginx/sites-available/default
mkdir -p /var/lib/nginx /var/log/nginx
touch /run/nginx.pid
chown -R nginx:nginx /etc/nginx /var/lib/nginx /var/log/nginx /run/nginx.pid
pkill nginx
sleep 1
su nginx -s /bin/bash -c '/usr/sbin/nginx'
